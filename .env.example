# =============================================================================
# QuantumBilling — environment template (DEV DEFAULTS, safe placeholders only)
#
# Generated from the story docs per ADR-001 / BUILD_PLAN. Keys collected from:
#   backend/phase_0_event_ingestion_pipeline.md   (ingest / Kafka / Redis / idempotency)
#   backend/story_5_batch_event_ingest.md         (Bloom filter sharding)
#   backend/story_6_migrations_health_observability.md (ClickHouse / OTLP / logging)
#   backend/story_7_kafka_setup_and_topic_configuration.md (broker / UI ports)
#   backend/phase_5_litellm_gateway_integration.md (LiteLLM / BYOK / callback)
#   uiflow organization/reports/dunning stories    (Keycloak / Stripe / SMTP)
#
# Copy to `.env` and adjust. NEVER commit a real `.env`.
# =============================================================================

# --- Ingest API (Phase 0) ----------------------------------------------------
PORT=8011
MAX_BATCH_SIZE=50000
LOG_LEVEL=info
LOG_FORMAT=json
SERVICE_VERSION=0.1.0
SHUTDOWN_TIMEOUT=30s

# --- Postgres (single instance: control plane + billing, ADR-001 §7.4) -------
POSTGRES_USER=quantum
POSTGRES_PASSWORD=quantum-dev-password
POSTGRES_DB=quantumbilling
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://quantum:quantum-dev-password@localhost:5432/quantumbilling

# --- Redis (redis-stack: key contexts, idempotency, existence caches, Bloom) -
REDIS_HOST_PORT=6379
REDIS_URL=redis://localhost:6379/0
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
# Idempotency SETNX TTL for idem:{org_id}:{event_id} (phase_0)
IDEMPOTENCY_TTL=24h
# Sharded Bloom filter shards per org for batch dedup (story_5, default 64)
BLOOM_NUM_SHARDS=64

# --- Kafka (KRaft single node, story_7) --------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=usage-events
KAFKA_ASYNC=true
KAFKA_BATCH_SIZE=1000000
KAFKA_BATCH_TIMEOUT=100ms
KAFKA_HOST_PORT=9092
KAFKA_ADVERTISED_HOST=127.0.0.1
KAFKA_NUM_PARTITIONS=32
KAFKA_UI_PORT=8085

# --- ClickHouse (events db — usage source of truth, story_6/story_9) ---------
CLICKHOUSE_ADDR=localhost:9000
CLICKHOUSE_DATABASE=events
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_MAX_CONNS=100
CLICKHOUSE_DIAL_TIMEOUT=10s
CLICKHOUSE_MAX_EXECUTION_TIME=60s

# --- Keycloak (Phase CP-2: realm, JWT validation in NestJS BFF) ---------------
KEYCLOAK_HOST_PORT=8080
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=quantumbilling
KEYCLOAK_CLIENT_ID=quantumbilling-bff
KEYCLOAK_CLIENT_SECRET=dev-bff-client-secret
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- Stripe (Track C: wallet top-ups CR-2, auto-collection CR-6) --------------
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# --- Billing worker (Track C: invoice engine) --------------------------------
INVOICE_GRACE_HOURS=36

# --- BYOK encryption (story_13 / phase_5) -------------------------------------
# DEV ONLY: raw env-var master key. Per ADR-001 §7 adopt KMS/Vault envelope
# encryption before production — never ship a raw AES master key in env.
BYOK_MASTER_KEY=dev-only-insecure-byok-master-key

# --- LiteLLM gateway (Phase 5) -------------------------------------------------
LITELLM_MASTER_KEY=sk-litellm-dev-master-key
LITELLM_PORT=4000
LITELLM_LOG_LEVEL=INFO
STORE_MODEL_IN_DB=True
LITELLM_POSTGRES_USER=llmproxy
LITELLM_POSTGRES_PASSWORD=dbpassword9090
LITELLM_POSTGRES_DB=litellm
LITELLM_POSTGRES_HOST_PORT=5433
# In-network URL used by the litellm container itself:
LITELLM_DATABASE_URL=postgresql://llmproxy:dbpassword9090@litellm-postgres:5432/litellm
# Ingest API endpoint targeted by the usage-event callback (story_21)
EVENT_ENGINE_INGEST_URL=http://host.docker.internal:8011/v1/events
CALLBACK_TIMEOUT=5s

# --- Service-to-service auth (phase 4 APIs <- NestJS BFF, ADR-001 §2) ---------
QB_SERVICE_TOKEN_SECRET=dev-service-token-secret-change-me

# --- SMTP (invitations, dunning, reports — uiflow stories) --------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=dev
SMTP_PASSWORD=dev
SMTP_FROM=noreply@quantumbilling.local

# --- Observability (story_6) ---------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ingest-api
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
PROMETHEUS_PORT=9090
