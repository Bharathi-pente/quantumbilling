// -----------------------------------------------------------------------------
// QuantumBilling — Prisma schema (control plane + billing artifacts)
//
// GENERATED FROM ERD.md (v1.2-reconciled, 2026-07-02). Authority split:
//   - ERD.md is the CONCEPTUAL canon: entities, relationships, enums, and the
//     Conflict Register resolutions (C-1..C-26).
//   - THIS FILE is the EXECUTABLE DDL authority: exact types, nullability,
//     indexes, constraints. Where the two differ, resolve through the ERD
//     Conflict Register — never leave a divergence as a comment.
// New tables required by ADR-001 core requirements (CR-1..CR-14) are marked
// in comments.
//
// OWNERSHIP: Prisma is the SINGLE DDL owner for ALL Postgres schemas listed in
// the datasource below — including the `billing` schema. Go services (billing
// worker, ingest/analytics workers) perform DML ONLY and never run migrations;
// see SCAFFOLD.md. One-writer rule per ADR-001 §2: NestJS writes control-plane
// config; the Go billing worker writes financial artifacts.
//
// NOT IN THIS DATABASE: ClickHouse `events.usage_events` (ERD §7, usage source
// of truth) and the LiteLLM gateway Postgres (ERD §8) are separate stores.
// `billing.usage_events` was deleted per ADR-001 §2 / Conflict C-1.
//
// MONEY & QUANTITIES: all monetary and quantity numerics use Decimal(38,9).
// Rounding rules are defined in BILLING_MATH.md.
// -----------------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["identity", "customer", "catalog", "billing", "developer", "security", "audit", "communication", "reporting", "analytics", "compliance", "platform", "workflow"]
}

