// CR-13 (new): warehouse-native export — scheduled sync of usage aggregates,
// invoices, and the recognition ledger to Snowflake/BigQuery/S3 parquet.
model ExportConfig {
  id           String    @id @default(uuid()) @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  name         String
  // snowflake|bigquery|s3_parquet — provider-pluggable, kept as text.
  destination  String
  // Connection/credentials reference (secrets live in KMS, not here).
  config       Json?
  // Which datasets to sync: usage_aggregates|invoices|revenue_recognition.
  datasets     Json?
  schedule     String?
  // active|paused|error — operational, kept as text.
  status       String    @default("active")
  lastSyncedAt DateTime? @map("last_synced_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@map("export_configs")
  @@schema("reporting")
}

