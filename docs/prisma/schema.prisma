// =============================================================================
// §1 IDENTITY & ORGANIZATION
// =============================================================================

model Organization {
  id           String             @id @default(uuid()) @db.Uuid
  name         String
  billingEmail String             @map("billing_email")
  currency     String
  country      String?
  industry     String?
  timezone     String?
  // Conflict C-14: column added per organization:263; trial state lives on
  // subscriptions (trialing), not orgs.
  status       OrganizationStatus @default(ACTIVE)
  suspendedAt  DateTime?          @map("suspended_at") @db.Timestamptz(6)
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  // identity
  users              User[]
  roles              Role[]
  invitations        Invitation[]
  onboardingProgress OnboardingProgress?

  // customer
  customers                  Customer[]
  endUsers                   EndUser[]
  subscriptions              Subscription[]
  usageLimits                UsageLimit[]
  entitlementPolicyVersions  EntitlementPolicyVersion[]

  // catalog
  meters           Meter[]
  products         Product[]
  features         Feature[]
  pricingModels    PricingModel[]
  rateCards        RateCard[]
  rateCardVersions RateCardVersion[]

  // billing
  invoices                  Invoice[]
  invoiceStatusHistory      InvoiceStatusHistory[]
  creditNotes               CreditNote[]
  reratingRuns              ReratingRun[]
  payments                  Payment[]
  paymentReconciliations    PaymentReconciliation[]
  credits                   Credit[]
  creditLedgerEntries       CreditLedgerEntry[]
  wallets                   Wallet[]
  revenueRecognitionEntries RevenueRecognitionEntry[]
  billingGroups             BillingGroup[]
  discounts                 Discount[]
  dunningPolicies           DunningPolicy[]
  taxRegions                TaxRegion[]
  taxExemptions             TaxExemption[]
  taxCalculationAudits      TaxCalculationAudit[]
  currencyConfigs           CurrencyConfig[]
  ratingExceptions          RatingException[]
  simulationRuns            SimulationRun[]

  // developer
  apiKeys            ApiKey[]
  virtualKeyMappings VirtualKeyMapping[]
  rateLimitUsages    RateLimitUsage[]
  webhooks           Webhook[]
  alerts             Alert[]
  alertChannels      AlertChannel[]
  alertChannelMaps   AlertChannelMap[]

  // security
  byokProviderKeys  ByokProviderKey[]
  securityAuditLogs SecurityAuditLog[]

  // platform
  auditLogs  AuditLog[]
  testClocks TestClock[]

  // compliance
  gdprRequests          GdprRequest[]
  complianceReports     ComplianceReport[]
  dataRetentionPolicies DataRetentionPolicy[]
  discrepancies         Discrepancy[]

  // reporting
  reports       Report[]
  exportConfigs ExportConfig[]

  // workflow
  approvalWorkflows ApprovalWorkflow[]
  approvalRequests  ApprovalRequest[]

  // analytics
  aiRecommendations      AiRecommendation[]
  aiRecommendationEvents AiRecommendationEvent[]
  churnRiskScores        ChurnRiskScore[]
  revenueInsights        RevenueInsight[]
  aiOrgSettings          AiOrgSetting[]

  // communication
  notificationTemplates    NotificationTemplate[]
  notificationDeliveryLogs NotificationDeliveryLog[]

  @@map("organizations")
  @@schema("identity")
}

model User {
  id         String @id @default(uuid()) @db.Uuid
  orgId      String @map("org_id") @db.Uuid
  roleId     String @map("role_id") @db.Uuid
  keycloakId String @map("keycloak_id")

  organization Organization @relation(fields: [orgId], references: [id])
  role         Role         @relation(fields: [roleId], references: [id])

  auditLogs              AuditLog[]
  approvalRequests       ApprovalRequest[]
  aiRecommendationEvents AiRecommendationEvent[]

  @@index([orgId])
  @@index([roleId])
  @@map("users")
  @@schema("identity")
}

model Role {
  id    String @id @default(uuid()) @db.Uuid
  orgId String @map("org_id") @db.Uuid
  // SUPER_ADMIN|ORG_ADMIN|CUSTOMER|END_USER|DEVELOPER — row data, not enum.
  name  String

  organization Organization     @relation(fields: [orgId], references: [id])
  permissions  RolePermission[]
  users        User[]
  invitations  Invitation[]

  @@index([orgId])
  @@map("roles")
  @@schema("identity")
}

model RolePermission {
  id         String @id @default(uuid()) @db.Uuid
  roleId     String @map("role_id") @db.Uuid
  // Columns never specified in source docs — inferred (ERD §11).
  permission String

  role Role @relation(fields: [roleId], references: [id])

  @@index([roleId])
  @@map("role_permissions")
  @@schema("identity")
}

model Invitation {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  email     String
  roleId    String   @map("role_id") @db.Uuid
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])
  role         Role         @relation(fields: [roleId], references: [id])

  @@index([orgId])
  @@index([roleId])
  @@map("invitations")
  @@schema("identity")
}

model OnboardingProgress {
  id          String  @id @default(uuid()) @db.Uuid
  orgId       String  @unique @map("org_id") @db.Uuid
  currentStep String  @map("current_step")
  isCompleted Boolean @default(false) @map("is_completed")

  organization Organization @relation(fields: [orgId], references: [id])

  @@map("onboarding_progress")
  @@schema("identity")
}

// =============================================================================
// §2 CUSTOMER DOMAIN
// =============================================================================

model Customer {
  id             String         @id @default(uuid()) @db.Uuid
  orgId          String         @map("org_id") @db.Uuid
  name           String
  email          String
  billingEmail   String?        @map("billing_email")
  billingAddress Json?          @map("billing_address")
  creditBalance  Decimal        @default(0) @map("credit_balance") @db.Decimal(38, 9)
  healthScore    Int?           @map("health_score")
  taxRegionId    String?        @map("tax_region_id") @db.Uuid
  // Conflict C-16 resolution: uppercase set per the Prisma enum & state machine.
  status         CustomerStatus @default(ACTIVE)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])
  taxRegion    TaxRegion?   @relation(fields: [taxRegionId], references: [id])

  contacts                  CustomerContact[]
  endUsers                  EndUser[]
  contracts                 Contract[]
  subscriptions             Subscription[]
  entitlementGrants         EntitlementGrant[]
  limitOverrides            LimitOverride[]
  usageSummaries            UsageSummary[]
  invoices                  Invoice[]
  creditNotes               CreditNote[]
  payments                  Payment[]
  paymentMethods            PaymentMethod[]
  credits                   Credit[]
  wallet                    Wallet?
  revenueRecognitionEntries RevenueRecognitionEntry[]
  billingGroupMemberships   BillingGroupMember[]
  dunningCommunications     DunningCommunication[]
  taxExemptions             TaxExemption[]
  taxCalculationAudits      TaxCalculationAudit[]
  ratingExceptions          RatingException[]
  apiKeys                   ApiKey[]
  securityAuditLogs         SecurityAuditLog[]
  gdprRequests              GdprRequest[]
  discrepancies             Discrepancy[]
  alertHistory              AlertHistory[]
  aiRecommendations         AiRecommendation[]
  churnRiskScores           ChurnRiskScore[]
  healthScores              CustomerHealthScore[]
  notificationDeliveryLogs  NotificationDeliveryLog[]

  @@index([orgId])
  @@index([taxRegionId])
  @@map("customers")
  @@schema("customer")
}

model CustomerContact {
  id          String  @id @default(uuid()) @db.Uuid
  customerId  String  @map("customer_id") @db.Uuid
  email       String
  designation String?
  isPrimary   Boolean @default(false) @map("is_primary")

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("customer_contacts")
  @@schema("customer")
}

model EndUser {
  id             String        @id @default(uuid()) @db.Uuid
  customerId     String        @map("customer_id") @db.Uuid
  orgId          String        @map("org_id") @db.Uuid
  externalUserId String        @map("external_user_id")
  name           String?
  email          String?
  status         EndUserStatus @default(active)
  metadata       Json?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  customer     Customer     @relation(fields: [customerId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])

  usageSummaries UsageSummary[]
  apiKeys        ApiKey[]

  @@index([customerId])
  @@index([orgId])
  @@map("end_users")
  @@schema("customer")
}

model Contract {
  id           String         @id @default(uuid()) @db.Uuid
  customerId   String         @map("customer_id") @db.Uuid
  // Negotiated pricing path (ADR-001 §3.3): contracts → rate_cards → contract_rates.
  rateCardId   String?        @map("rate_card_id") @db.Uuid
  name         String
  commitAmount Decimal        @default(0) @map("commit_amount") @db.Decimal(38, 9)
  autoRenew    Boolean        @default(false) @map("auto_renew")
  status       ContractStatus @default(DRAFT)
  startDate    DateTime       @map("start_date") @db.Date
  endDate      DateTime       @map("end_date") @db.Date
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer Customer  @relation(fields: [customerId], references: [id])
  rateCard RateCard? @relation(fields: [rateCardId], references: [id])

  // Conflict C-13: subscription carries contract_id.
  subscriptions Subscription[]
  contractRates ContractRate[]
  discounts     Discount[]

  @@index([customerId])
  @@index([rateCardId])
  @@map("contracts")
  @@schema("customer")
}

model Subscription {
  id                 String             @id @default(uuid()) @db.Uuid
  orgId              String             @map("org_id") @db.Uuid
  customerId         String             @map("customer_id") @db.Uuid
  planId             String             @map("plan_id") @db.Uuid
  contractId         String?            @map("contract_id") @db.Uuid
  // Conflict C-12: merged customer/billing subscriptions; lowercase status set.
  status             SubscriptionStatus @default(scheduled)
  billingPeriod      BillingPeriod      @map("billing_period")
  startDate          DateTime           @map("start_date") @db.Date
  endDate            DateTime?          @map("end_date") @db.Date
  // Anniversary window — ADR-001 §3.1.
  currentPeriodStart DateTime           @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd   DateTime           @map("current_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd  Boolean            @default(false) @map("cancel_at_period_end")
  // CR-14 trials.
  trialEnd           DateTime?          @map("trial_end") @db.Timestamptz(6)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  plan         Plan         @relation(fields: [planId], references: [id])
  contract     Contract?    @relation(fields: [contractId], references: [id])

  invoices Invoice[]

  @@index([orgId])
  @@index([customerId])
  @@index([planId])
  @@index([contractId])
  @@map("subscriptions")
  @@schema("customer")
}

model EntitlementGrant {
  id         String                 @id @default(uuid()) @db.Uuid
  customerId String                 @map("customer_id") @db.Uuid
  featureId  String                 @map("feature_id") @db.Uuid
  scope      EntitlementScope       @default(global)
  reason     String?
  status     EntitlementGrantStatus @default(GRANTED)
  grantedAt  DateTime               @default(now()) @map("granted_at") @db.Timestamptz(6)
  // null = perpetual
  expiresAt  DateTime?              @map("expires_at") @db.Timestamptz(6)

  customer Customer @relation(fields: [customerId], references: [id])
  feature  Feature  @relation(fields: [featureId], references: [id])

  @@index([customerId])
  @@index([featureId])
  @@map("entitlement_grants")
  @@schema("customer")
}

// Conflict C-10: customer.customer_limits merged into this table;
// token-specific caps become meter-scoped rows. Conflict C-17: DB enums win.
model UsageLimit {
  id         String      @id @default(uuid()) @db.Uuid
  orgId      String      @map("org_id") @db.Uuid
  productId  String      @map("product_id") @db.Uuid
  meterId    String      @map("meter_id") @db.Uuid
  limitType  LimitType   @map("limit_type")
  limitValue Decimal     @map("limit_value") @db.Decimal(38, 9)
  period     LimitPeriod

  organization Organization @relation(fields: [orgId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  meter        Meter        @relation(fields: [meterId], references: [id])

  @@index([orgId])
  @@index([productId])
  @@index([meterId])
  @@map("usage_limits")
  @@schema("customer")
}

model LimitOverride {
  id            String              @id @default(uuid()) @db.Uuid
  customerId    String              @map("customer_id") @db.Uuid
  meterId       String              @map("meter_id") @db.Uuid
  originalLimit Decimal             @map("original_limit") @db.Decimal(38, 9)
  newLimit      Decimal             @map("new_limit") @db.Decimal(38, 9)
  status        LimitOverrideStatus @default(ACTIVE)
  expiresAt     DateTime?           @map("expires_at") @db.Timestamptz(6)
  createdBy     String?             @map("created_by") @db.Uuid

  customer Customer @relation(fields: [customerId], references: [id])
  meter    Meter    @relation(fields: [meterId], references: [id])

  @@index([customerId])
  @@index([meterId])
  @@map("limit_overrides")
  @@schema("customer")
}

// ADR-001: materialized rollup FED FROM CLICKHOUSE — display only, never used
// for enforcement (Redis) or invoicing (ClickHouse dedup view).
model UsageSummary {
  id          String   @id @default(uuid()) @db.Uuid
  customerId  String   @map("customer_id") @db.Uuid
  endUserId   String   @map("end_user_id") @db.Uuid
  meterId     String   @map("meter_id") @db.Uuid
  periodStart DateTime @map("period_start") @db.Timestamptz(6)
  periodEnd   DateTime @map("period_end") @db.Timestamptz(6)
  totalUsage  Decimal  @map("total_usage") @db.Decimal(38, 9)
  totalCost   Decimal  @map("total_cost") @db.Decimal(38, 9)

  customer Customer @relation(fields: [customerId], references: [id])
  endUser  EndUser  @relation(fields: [endUserId], references: [id])
  meter    Meter    @relation(fields: [meterId], references: [id])

  @@index([customerId])
  @@index([endUserId])
  @@index([meterId])
  @@map("usage_summary")
  @@schema("customer")
}

model EntitlementPolicyVersion {
  id                    String                @id @default(uuid()) @db.Uuid
  // Logical ref — no entitlement_policies table exists in the ERD.
  entitlementPolicyId   String                @map("entitlement_policy_id") @db.Uuid
  orgId                 String                @map("org_id") @db.Uuid
  version               Int
  changeType            EntitlementChangeType @map("change_type")
  snapshotData          Json                  @map("snapshot_data")
  changeSummary         String?               @map("change_summary")
  createdBy             String?               @map("created_by") @db.Uuid
  createdAt             DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([entitlementPolicyId])
  @@map("entitlement_policy_versions")
  @@schema("customer")
}

// =============================================================================
// §3 CATALOG — products, plans, pricing, meters, rate cards
// =============================================================================

model Meter {
  id          String           @id @default(uuid()) @db.Uuid
  orgId       String           @map("org_id") @db.Uuid
  name        String
  // NOT meter_type (meter:309); supports outcome/agent-action events — CR-10.
  eventType   String           @map("event_type")
  // Conflict C-15: event_type + aggregation, NOT unit.
  aggregation MeterAggregation
  field       String?
  status      MeterStatus      @default(DRAFT)
  lastEventAt DateTime?        @map("last_event_at") @db.Timestamptz(6)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])

  charges          Charge[]
  pricingModels    PricingModel[]
  rateCardRates    RateCardRate[]
  usageLimits      UsageLimit[]
  limitOverrides   LimitOverride[]
  usageSummaries   UsageSummary[]
  invoiceLineItems InvoiceLineItem[]
  contractRates    ContractRate[]
  ratingExceptions RatingException[]

  @@index([orgId])
  @@map("meters")
  @@schema("catalog")
}

model Product {
  id           String              @id @default(uuid()) @db.Uuid
  orgId        String              @map("org_id") @db.Uuid
  // SKU — NOT sku (product:339).
  productCode  String              @map("product_code")
  productName  String              @map("product_name")
  description  String?
  productType  ProductType         @map("product_type")
  billingModel ProductBillingModel @map("billing_model")
  status       ProductStatus       @default(DRAFT)
  isPublic     Boolean             @default(false) @map("is_public")
  metadata     Json?
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])

  productFeatures   ProductFeature[]
  plans             Plan[]
  usageLimits       UsageLimit[]
  rateLimitPolicies RateLimitPolicy[]

  @@unique([orgId, productCode])
  @@index([orgId])
  @@map("products")
  @@schema("catalog")
}

model Feature {
  id       String  @id @default(uuid()) @db.Uuid
  orgId    String  @map("org_id") @db.Uuid
  name     String
  category String?
  // No closed value set given in the ERD — kept as text.
  status   String?

  organization Organization @relation(fields: [orgId], references: [id])

  productFeatures   ProductFeature[]
  planFeatures      PlanFeature[]
  entitlementGrants EntitlementGrant[]

  @@index([orgId])
  @@map("features")
  @@schema("catalog")
}

model ProductFeature {
  id        String @id @default(uuid()) @db.Uuid
  productId String @map("product_id") @db.Uuid
  featureId String @map("feature_id") @db.Uuid

  product Product @relation(fields: [productId], references: [id])
  feature Feature @relation(fields: [featureId], references: [id])

  @@index([productId])
  @@index([featureId])
  @@map("product_features")
  @@schema("catalog")
}

model Plan {
  id             String        @id @default(uuid()) @db.Uuid
  productId      String        @map("product_id") @db.Uuid
  name           String
  slug           String
  billingPeriod  BillingPeriod @map("billing_period")
  // CR-14 trials.
  trialDays      Int?          @map("trial_days")
  // Conflict C-5: base_amount / is_active — NOT base_price / status.
  baseAmount     Decimal       @default(0) @map("base_amount") @db.Decimal(38, 9)
  currency       String
  payInAdvance   Boolean       @default(false) @map("pay_in_advance")
  isActive       Boolean       @default(true) @map("is_active")
  // CR-14: monthly included credits, reset on anniversary.
  recurringGrant Json?         @map("recurring_grant")
  // CR-3: per-seat pricing.
  seatIncluded   Int?          @map("seat_included")
  seatPrice      Decimal?      @map("seat_price") @db.Decimal(38, 9)

  product Product @relation(fields: [productId], references: [id])

  planFeatures  PlanFeature[]
  versions      PlanVersion[]
  charges       Charge[]
  subscriptions Subscription[]

  @@index([productId])
  @@map("plans")
  @@schema("catalog")
}

model PlanFeature {
  id         String   @id @default(uuid()) @db.Uuid
  planId     String   @map("plan_id") @db.Uuid
  featureId  String   @map("feature_id") @db.Uuid
  limitValue Decimal? @map("limit_value") @db.Decimal(38, 9)

  plan    Plan    @relation(fields: [planId], references: [id])
  feature Feature @relation(fields: [featureId], references: [id])

  @@index([planId])
  @@index([featureId])
  @@map("plan_features")
  @@schema("catalog")
}

// CR-1 / ADR-001 §3.2 (new): plan-change history for proration and re-rating.
model PlanVersion {
  id            String    @id @default(uuid()) @db.Uuid
  planId        String    @map("plan_id") @db.Uuid
  version       Int
  snapshotData  Json      @map("snapshot_data")
  effectiveFrom DateTime  @map("effective_from") @db.Timestamptz(6)
  effectiveTo   DateTime? @map("effective_to") @db.Timestamptz(6)

  plan Plan @relation(fields: [planId], references: [id])

  @@index([planId])
  @@map("plan_versions")
  @@schema("catalog")
}

model Charge {
  id            String      @id @default(uuid()) @db.Uuid
  planId        String      @map("plan_id") @db.Uuid
  meterId       String      @map("meter_id") @db.Uuid
  name          String
  chargeType    String?     @map("charge_type")
  chargeModel   PricingType @map("charge_model")
  billingModel  String?     @map("billing_model")
  // Allowance before overage — ADR-001 §3.
  includedUnits Decimal     @default(0) @map("included_units") @db.Decimal(38, 9)
  payInAdvance  Boolean     @default(false) @map("pay_in_advance")
  isActive      Boolean     @default(true) @map("is_active")

  plan  Plan  @relation(fields: [planId], references: [id])
  meter Meter @relation(fields: [meterId], references: [id])

  @@index([planId])
  @@index([meterId])
  @@map("charges")
  @@schema("catalog")
}

// Packaged pricing path (product-led): plans → charges → pricing_models
// (ADR-001 §3.3, Conflict C-24).
model PricingModel {
  id            String        @id @default(uuid()) @db.Uuid
  orgId         String        @map("org_id") @db.Uuid
  meterId       String?       @map("meter_id") @db.Uuid
  name          String
  pricingType   PricingType   @map("pricing_type")
  // Matrix dimensions (model x token_type), package size, markup pct.
  config        Json?
  // CR-3: per-period minimum / cap.
  minimumAmount Decimal?      @map("minimum_amount") @db.Decimal(38, 9)
  maximumAmount Decimal?      @map("maximum_amount") @db.Decimal(38, 9)
  effectiveFrom DateTime?     @map("effective_from") @db.Date
  // Optimistic lock (pricing notes).
  version       Int           @default(1)
  status        CatalogStatus @default(DRAFT)

  organization Organization @relation(fields: [orgId], references: [id])
  meter        Meter?       @relation(fields: [meterId], references: [id])

  tiers PricingTier[]

  @@index([orgId])
  @@index([meterId])
  @@map("pricing_models")
  @@schema("catalog")
}

model PricingTier {
  id             String   @id @default(uuid()) @db.Uuid
  pricingModelId String   @map("pricing_model_id") @db.Uuid
  fromQty        Decimal  @map("from_qty") @db.Decimal(38, 9)
  // null = unbounded
  toQty          Decimal? @map("to_qty") @db.Decimal(38, 9)
  pricePerUnit   Decimal  @map("price_per_unit") @db.Decimal(38, 9)
  sortOrder      Int      @map("sort_order")

  pricingModel PricingModel @relation(fields: [pricingModelId], references: [id])

  @@index([pricingModelId])
  @@map("pricing_tiers")
  @@schema("catalog")
}

// Negotiated pricing path (sales-led): contracts → rate_cards → contract_rates
// (ADR-001 §3.3, Conflict C-24).
model RateCard {
  id            String        @id @default(uuid()) @db.Uuid
  orgId         String        @map("org_id") @db.Uuid
  name          String
  effectiveDate DateTime?     @map("effective_date") @db.Date
  status        CatalogStatus @default(DRAFT)

  organization Organization @relation(fields: [orgId], references: [id])

  rates     RateCardRate[]
  versions  RateCardVersion[]
  contracts Contract[]

  @@index([orgId])
  @@map("rate_cards")
  @@schema("catalog")
}

model RateCardRate {
  id         String     @id @default(uuid()) @db.Uuid
  rateCardId String     @map("rate_card_id") @db.Uuid
  meterId    String     @map("meter_id") @db.Uuid
  // LLM model for matrix pricing.
  modelName  String?    @map("model_name")
  // CR-3 matrix dimension.
  tokenType  TokenType? @map("token_type")
  rate       Decimal    @db.Decimal(38, 9)
  unitLabel  String?    @map("unit_label")

  rateCard RateCard @relation(fields: [rateCardId], references: [id])
  meter    Meter    @relation(fields: [meterId], references: [id])

  @@index([rateCardId])
  @@index([meterId])
  @@map("rate_card_rates")
  @@schema("catalog")
}

// Conflict C-2: canonical schema is catalog — it versions a catalog entity.
model RateCardVersion {
  id            String   @id @default(uuid()) @db.Uuid
  rateCardId    String   @map("rate_card_id") @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  version       Int
  changeType    String?  @map("change_type")
  snapshotData  Json     @map("snapshot_data")
  changeSummary String?  @map("change_summary")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  rateCard     RateCard     @relation(fields: [rateCardId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])

  @@index([rateCardId])
  @@index([orgId])
  @@map("rate_card_versions")
  @@schema("catalog")
}

// =============================================================================
// §4 BILLING — invoices, payments, credits, wallet, dunning, tax
// Written exclusively by the Go billing worker (DML), except configuration
// tables (dunning_policies, tax_regions, currency_config, billing_groups,
// wallet config), which NestJS writes. DDL stays Prisma-owned.
// =============================================================================

model Invoice {
  id                   String        @id @default(uuid()) @db.Uuid
  orgId                String        @map("org_id") @db.Uuid
  customerId           String        @map("customer_id") @db.Uuid
  subscriptionId       String        @map("subscription_id") @db.Uuid
  // CR-8 consolidated billing.
  groupId              String?       @map("group_id") @db.Uuid
  // Conflict C-19: invoice_number / total / credits_applied.
  // Format INV-YYYY-MM-NNN.
  invoiceNumber        String        @map("invoice_number")
  status               InvoiceStatus @default(draft)
  periodStart          DateTime      @map("period_start") @db.Timestamptz(6)
  periodEnd            DateTime      @map("period_end") @db.Timestamptz(6)
  subtotal             Decimal       @db.Decimal(38, 9)
  creditsApplied       Decimal       @default(0) @map("credits_applied") @db.Decimal(38, 9)
  taxRate              Decimal       @default(0) @map("tax_rate") @db.Decimal(38, 9)
  taxAmount            Decimal       @default(0) @map("tax_amount") @db.Decimal(38, 9)
  total                Decimal       @db.Decimal(38, 9)
  currency             String
  dueDate              DateTime?     @map("due_date") @db.Date
  issuedAt             DateTime?     @map("issued_at") @db.Timestamptz(6)
  paidAt               DateTime?     @map("paid_at") @db.Timestamptz(6)
  // CR-1 reproducibility: input snapshot refs (logical — snapshots live in
  // catalog.rate_card_versions / catalog.plan_versions).
  rateCardVersionId    String?       @map("rate_card_version_id") @db.Uuid
  planVersionId        String?       @map("plan_version_id") @db.Uuid
  // CR-1: ClickHouse read watermark.
  aggregationWatermark DateTime?     @map("aggregation_watermark") @db.Timestamptz(6)

  organization Organization  @relation(fields: [orgId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  subscription Subscription  @relation(fields: [subscriptionId], references: [id])
  group        BillingGroup? @relation(fields: [groupId], references: [id])

  lineItems                 InvoiceLineItem[]
  statusHistory             InvoiceStatusHistory[]
  payments                  Payment[]
  creditLedgerEntries       CreditLedgerEntry[]
  creditNotes               CreditNote[]
  dunningCommunications     DunningCommunication[]
  taxCalculationAudits      TaxCalculationAudit[]

  @@index([orgId])
  @@index([customerId])
  @@index([subscriptionId])
  @@index([groupId])
  @@map("invoices")
  @@schema("billing")
}

model InvoiceLineItem {
  id             String       @id @default(uuid()) @db.Uuid
  invoiceId      String       @map("invoice_id") @db.Uuid
  meterId        String?      @map("meter_id") @db.Uuid
  lineType       LineItemType @map("line_type")
  description    String?
  quantity       Decimal      @default(0) @db.Decimal(38, 9)
  unitPrice      Decimal      @default(0) @map("unit_price") @db.Decimal(38, 9)
  amount         Decimal      @db.Decimal(38, 9)
  // LLM model attribution.
  model          String?
  // Attribution under CR-8 grouping (logical ref, no FK by design).
  subscriptionId String?      @map("subscription_id") @db.Uuid
  // ADR-001 §3.3 waterfall provenance.
  rateSource     RateSource?  @map("rate_source")
  // Id of the resolved rate row — CR-1 reproducibility (polymorphic ref).
  rateSourceId   String?      @map("rate_source_id") @db.Uuid

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  meter   Meter?  @relation(fields: [meterId], references: [id])

  @@index([invoiceId])
  @@index([meterId])
  @@index([subscriptionId])
  @@map("invoice_line_items")
  @@schema("billing")
}

model InvoiceStatusHistory {
  id        String   @id @default(uuid()) @db.Uuid
  invoiceId String   @map("invoice_id") @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  oldStatus String?  @map("old_status")
  newStatus String   @map("new_status")
  changedBy String?  @map("changed_by") @db.Uuid
  changedAt DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)

  invoice      Invoice      @relation(fields: [invoiceId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])

  @@index([invoiceId])
  @@index([orgId])
  @@map("invoice_status_history")
  @@schema("billing")
}

// CR-1/CR-4 (new): correction primitive — issued invoices are never mutated.
model CreditNote {
  id            String           @id @default(uuid()) @db.Uuid
  orgId         String           @map("org_id") @db.Uuid
  customerId    String           @map("customer_id") @db.Uuid
  invoiceId     String           @map("invoice_id") @db.Uuid
  reratingRunId String?          @map("rerating_run_id") @db.Uuid
  noteNumber    String           @map("note_number")
  kind          CreditNoteKind
  amount        Decimal          @db.Decimal(38, 9)
  currency      String
  reason        String?
  status        CreditNoteStatus @default(draft)
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  invoice      Invoice      @relation(fields: [invoiceId], references: [id])
  reratingRun  ReratingRun? @relation(fields: [reratingRunId], references: [id])

  @@index([orgId])
  @@index([customerId])
  @@index([invoiceId])
  @@index([reratingRunId])
  @@map("credit_notes")
  @@schema("billing")
}

// CR-1 (new): re-rate a period, diff vs issued invoice.
model ReratingRun {
  id                String          @id @default(uuid()) @db.Uuid
  orgId             String          @map("org_id") @db.Uuid
  periodStart       DateTime        @map("period_start") @db.Timestamptz(6)
  periodEnd         DateTime        @map("period_end") @db.Timestamptz(6)
  scope             ReratingScope
  trigger           ReratingTrigger
  inputSnapshotRefs Json?           @map("input_snapshot_refs")
  diffTotal         Decimal?        @map("diff_total") @db.Decimal(38, 9)
  status            ReratingStatus  @default(pending)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])
  creditNotes  CreditNote[]

  @@index([orgId])
  @@map("rerating_runs")
  @@schema("billing")
}

model Payment {
  id              String         @id @default(uuid()) @db.Uuid
  orgId           String         @map("org_id") @db.Uuid
  customerId      String         @map("customer_id") @db.Uuid
  invoiceId       String         @map("invoice_id") @db.Uuid
  paymentMethodId String         @map("payment_method_id") @db.Uuid
  amount          Decimal        @db.Decimal(38, 9)
  currency        String
  status          PaymentStatus  @default(PENDING)
  // CR-6.
  collectionMode  CollectionMode @map("collection_mode")
  failureReason   String?        @map("failure_reason")
  description     String?
  paymentDate     DateTime?      @map("payment_date") @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy       String?        @map("created_by") @db.Uuid
  // Immutable — corrections via credit note.
  deletedAt       DateTime?      @map("deleted_at") @db.Timestamptz(6)

  organization  Organization  @relation(fields: [orgId], references: [id])
  customer      Customer      @relation(fields: [customerId], references: [id])
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  reconciliation     PaymentReconciliation?
  walletTransactions WalletTransaction[]

  @@index([orgId])
  @@index([customerId])
  @@index([invoiceId])
  @@index([paymentMethodId])
  @@map("payments")
  @@schema("billing")
}

// Conflict C-6: customer-attached (the payer is the customer); method_type/last4.
model PaymentMethod {
  id             String            @id @default(uuid()) @db.Uuid
  customerId     String            @map("customer_id") @db.Uuid
  methodType     PaymentMethodType @map("method_type")
  // Stripe token — card data never stored.
  gatewayToken   String?           @map("gateway_token")
  brand          String?
  last4          String?
  expMonth       Int?              @map("exp_month")
  expYear        Int?              @map("exp_year")
  bankName       String?           @map("bank_name")
  billingName    String?           @map("billing_name")
  billingAddress Json?             @map("billing_address")
  isDefault      Boolean           @default(false) @map("is_default")
  // No closed value set given in the ERD — kept as text.
  status         String?
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?         @map("deleted_at") @db.Timestamptz(6)

  customer Customer @relation(fields: [customerId], references: [id])

  payments      Payment[]
  topupWallets  Wallet[]

  @@index([customerId])
  @@map("payment_methods")
  @@schema("billing")
}

model PaymentReconciliation {
  id               String               @id @default(uuid()) @db.Uuid
  orgId            String               @map("org_id") @db.Uuid
  paymentId        String               @unique @map("payment_id") @db.Uuid
  gatewayReference String?              @map("gateway_reference")
  status           ReconciliationStatus @default(PENDING)
  reconciledAt     DateTime?            @map("reconciled_at") @db.Timestamptz(6)
  triggeredBy      String?              @map("triggered_by") @db.Uuid
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])
  payment      Payment      @relation(fields: [paymentId], references: [id])

  @@index([orgId])
  @@map("payment_reconciliation")
  @@schema("billing")
}

// Conflict C-18: both org_id and customer_id (customer-scoped, org-filterable);
// remaining_amount.
model Credit {
  id              String       @id @default(uuid()) @db.Uuid
  orgId           String       @map("org_id") @db.Uuid
  customerId      String       @map("customer_id") @db.Uuid
  // FEFO within priority: compensation(0)|promotional(1)|prepaid(2)|commit(3).
  type            CreditType
  originalAmount  Decimal      @map("original_amount") @db.Decimal(38, 9)
  remainingAmount Decimal      @map("remaining_amount") @db.Decimal(38, 9)
  usedAmount      Decimal      @default(0) @map("used_amount") @db.Decimal(38, 9)
  priority        Int          @default(0)
  applicableTo    String?      @map("applicable_to")
  status          CreditStatus @default(active)
  notes           String?
  expiresAt       DateTime?    @map("expires_at") @db.Timestamptz(6)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])

  ledgerEntries CreditLedgerEntry[]

  @@index([orgId])
  @@index([customerId])
  @@map("credits")
  @@schema("billing")
}

model CreditLedgerEntry {
  id          String           @id @default(uuid()) @db.Uuid
  orgId       String           @map("org_id") @db.Uuid
  creditId    String           @map("credit_id") @db.Uuid
  invoiceId   String?          @map("invoice_id") @db.Uuid
  type        CreditLedgerType
  amount      Decimal          @db.Decimal(38, 9)
  balance     Decimal          @db.Decimal(38, 9)
  description String?
  // Usage event ref (ClickHouse event_id — logical link only).
  eventId     String?          @map("event_id")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])
  credit       Credit       @relation(fields: [creditId], references: [id])
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id])

  @@index([orgId])
  @@index([creditId])
  @@index([invoiceId])
  @@map("credit_ledger")
  @@schema("billing")
}

// CR-2 (new): real-time prepaid burndown. Redis is the enforcement cache;
// this row is the system of record, reconciled nightly.
model Wallet {
  id                    String       @id @default(uuid()) @db.Uuid
  orgId                 String       @map("org_id") @db.Uuid
  customerId            String       @unique @map("customer_id") @db.Uuid
  balance               Decimal      @default(0) @db.Decimal(38, 9)
  currency              String
  lowBalanceThreshold   Decimal?     @map("low_balance_threshold") @db.Decimal(38, 9)
  autoTopupEnabled      Boolean      @default(false) @map("auto_topup_enabled")
  topupAmount           Decimal?     @map("topup_amount") @db.Decimal(38, 9)
  topupPaymentMethodId  String?      @map("topup_payment_method_id") @db.Uuid
  status                WalletStatus @default(active)
  updatedAt             DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization       Organization   @relation(fields: [orgId], references: [id])
  customer           Customer       @relation(fields: [customerId], references: [id])
  topupPaymentMethod PaymentMethod? @relation(fields: [topupPaymentMethodId], references: [id])

  transactions WalletTransaction[]

  @@index([orgId])
  @@index([topupPaymentMethodId])
  @@map("wallets")
  @@schema("billing")
}

// CR-2 (new).
model WalletTransaction {
  id           String                @id @default(uuid()) @db.Uuid
  walletId     String                @map("wallet_id") @db.Uuid
  type         WalletTransactionType
  amount       Decimal               @db.Decimal(38, 9)
  balanceAfter Decimal               @map("balance_after") @db.Decimal(38, 9)
  paymentId    String?               @map("payment_id") @db.Uuid
  // Burndown aggregation window.
  periodRef    String?               @map("period_ref")
  createdAt    DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  wallet  Wallet   @relation(fields: [walletId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@index([walletId])
  @@index([paymentId])
  @@map("wallet_transactions")
  @@schema("billing")
}

// CR-5 (new): ASC 606 / IFRS 15 — deferred vs recognized revenue.
model RevenueRecognitionEntry {
  id                String           @id @default(uuid()) @db.Uuid
  orgId             String           @map("org_id") @db.Uuid
  customerId        String           @map("customer_id") @db.Uuid
  // Polymorphic ref (invoice | credit | wallet_transaction) — logical, no FK.
  sourceId          String           @map("source_id") @db.Uuid
  sourceType        RevRecSourceType @map("source_type")
  entryType         RevRecEntryType  @map("entry_type")
  amount            Decimal          @db.Decimal(38, 9)
  recognitionPeriod DateTime         @map("recognition_period") @db.Date
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])

  @@index([orgId])
  @@index([customerId])
  @@index([sourceId])
  @@map("revenue_recognition_ledger")
  @@schema("billing")
}

// CR-8 (new): consolidated invoicing.
model BillingGroup {
  id        String            @id @default(uuid()) @db.Uuid
  orgId     String            @map("org_id") @db.Uuid
  name      String
  level     BillingGroupLevel
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])

  invoices Invoice[]
  members  BillingGroupMember[]

  @@index([orgId])
  @@map("billing_groups")
  @@schema("billing")
}

// CR-8 (new): group membership — customers rolled up into a billing group.
model BillingGroupMember {
  id         String   @id @default(uuid()) @db.Uuid
  groupId    String   @map("group_id") @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  group    BillingGroup @relation(fields: [groupId], references: [id])
  customer Customer     @relation(fields: [customerId], references: [id])

  @@unique([groupId, customerId])
  @@index([groupId])
  @@index([customerId])
  @@map("billing_group_members")
  @@schema("billing")
}

// Negotiated path rate override — first stop in the ADR-001 §3.3 waterfall.
model ContractRate {
  id            String    @id @default(uuid()) @db.Uuid
  contractId    String    @map("contract_id") @db.Uuid
  meterId       String    @map("meter_id") @db.Uuid
  modelName     String?   @map("model_name")
  rate          Decimal   @db.Decimal(38, 9)
  unitLabel     String?   @map("unit_label")
  effectiveDate DateTime? @map("effective_date") @db.Date
  expiresDate   DateTime? @map("expires_date") @db.Date

  contract Contract @relation(fields: [contractId], references: [id])
  meter    Meter    @relation(fields: [meterId], references: [id])

  @@index([contractId])
  @@index([meterId])
  @@map("contract_rates")
  @@schema("billing")
}

model Discount {
  id            String       @id @default(uuid()) @db.Uuid
  orgId         String       @map("org_id") @db.Uuid
  contractId    String       @map("contract_id") @db.Uuid
  discountType  DiscountType @map("discount_type")
  discountValue Decimal      @map("discount_value") @db.Decimal(38, 9)
  priority      Int          @default(0)
  effectiveDate DateTime?    @map("effective_date") @db.Date
  expiresDate   DateTime?    @map("expires_date") @db.Date

  organization Organization @relation(fields: [orgId], references: [id])
  contract     Contract     @relation(fields: [contractId], references: [id])

  @@index([orgId])
  @@index([contractId])
  @@map("discounts")
  @@schema("billing")
}

model DunningPolicy {
  id            String              @id @default(uuid()) @db.Uuid
  orgId         String              @map("org_id") @db.Uuid
  name          String
  retrySchedule Json?               @map("retry_schedule")
  isDefault     Boolean             @default(false) @map("is_default")
  status        DunningPolicyStatus @default(DRAFT)

  organization Organization @relation(fields: [orgId], references: [id])

  steps          DunningStep[]
  communications DunningCommunication[]

  @@index([orgId])
  @@map("dunning_policies")
  @@schema("billing")
}

model DunningStep {
  id         String        @id @default(uuid()) @db.Uuid
  policyId   String        @map("policy_id") @db.Uuid
  stepOrder  Int           @map("step_order")
  action     DunningAction
  dayOffset  Int           @map("day_offset")
  escalateTo String?       @map("escalate_to")

  policy DunningPolicy @relation(fields: [policyId], references: [id])

  communications DunningCommunication[]

  @@index([policyId])
  @@map("dunning_steps")
  @@schema("billing")
}

model DunningCommunication {
  id              String            @id @default(uuid()) @db.Uuid
  dunningPolicyId String            @map("dunning_policy_id") @db.Uuid
  dunningStepId   String            @map("dunning_step_id") @db.Uuid
  invoiceId       String            @map("invoice_id") @db.Uuid
  customerId      String            @map("customer_id") @db.Uuid
  channel         String
  status          DunningCommStatus @default(PENDING)

  dunningPolicy DunningPolicy @relation(fields: [dunningPolicyId], references: [id])
  dunningStep   DunningStep   @relation(fields: [dunningStepId], references: [id])
  invoice       Invoice       @relation(fields: [invoiceId], references: [id])
  customer      Customer      @relation(fields: [customerId], references: [id])

  @@index([dunningPolicyId])
  @@index([dunningStepId])
  @@index([invoiceId])
  @@index([customerId])
  @@map("dunning_communications")
  @@schema("billing")
}

// Internal fallback — CR-7 tax provider is primary.
model TaxRegion {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  countryCode String   @map("country_code")
  stateCode   String?  @map("state_code")
  name        String
  rate        Decimal  @db.Decimal(38, 9)
  taxType     TaxType  @map("tax_type")
  // No closed value set given in the ERD — kept as text.
  status      String?

  organization Organization @relation(fields: [orgId], references: [id])

  customers            Customer[]
  taxCalculationAudits TaxCalculationAudit[]

  @@unique([orgId, countryCode, stateCode])
  @@index([orgId])
  @@map("tax_regions")
  @@schema("billing")
}

model TaxExemption {
  id            String             @id @default(uuid()) @db.Uuid
  customerId    String             @map("customer_id") @db.Uuid
  orgId         String             @map("org_id") @db.Uuid
  certificateId String?            @map("certificate_id")
  reason        String?
  status        TaxExemptionStatus @default(active)
  expiresAt     DateTime?          @map("expires_at") @db.Timestamptz(6)

  customer     Customer     @relation(fields: [customerId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])

  taxCalculationAudits TaxCalculationAudit[]

  @@index([customerId])
  @@index([orgId])
  @@map("tax_exemptions")
  @@schema("billing")
}

model TaxCalculationAudit {
  id            String       @id @default(uuid()) @db.Uuid
  invoiceId     String       @map("invoice_id") @db.Uuid
  orgId         String       @map("org_id") @db.Uuid
  customerId    String       @map("customer_id") @db.Uuid
  taxRegionId   String?      @map("tax_region_id") @db.Uuid
  exemptionId   String?      @map("exemption_id") @db.Uuid
  taxableAmount Decimal      @map("taxable_amount") @db.Decimal(38, 9)
  taxRate       Decimal      @map("tax_rate") @db.Decimal(38, 9)
  taxAmount     Decimal      @map("tax_amount") @db.Decimal(38, 9)
  taxType       TaxType?     @map("tax_type")
  // CR-7 pluggable provider.
  taxProvider   TaxProvider  @default(internal) @map("tax_provider")
  providerRefId String?      @map("provider_ref_id")
  calculatedAt  DateTime     @default(now()) @map("calculated_at") @db.Timestamptz(6)

  invoice      Invoice       @relation(fields: [invoiceId], references: [id])
  organization Organization  @relation(fields: [orgId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  taxRegion    TaxRegion?    @relation(fields: [taxRegionId], references: [id])
  exemption    TaxExemption? @relation(fields: [exemptionId], references: [id])

  @@index([invoiceId])
  @@index([orgId])
  @@index([customerId])
  @@index([taxRegionId])
  @@index([exemptionId])
  @@map("tax_calculation_audit")
  @@schema("billing")
}

model CurrencyConfig {
  id                  String   @id @default(uuid()) @db.Uuid
  orgId               String   @map("org_id") @db.Uuid
  baseCurrency        String   @map("base_currency")
  supportedCurrencies Json?    @map("supported_currencies")
  exchangeRates       Json?    @map("exchange_rates")
  lastUpdated         DateTime @default(now()) @map("last_updated") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@map("currency_config")
  @@schema("billing")
}

// ADR-001 §3.3 (new): waterfall step 4 — unrated usage is flagged here,
// never silently dropped and never billed at an implicit zero.
model RatingException {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  customerId  String    @map("customer_id") @db.Uuid
  meterId     String?   @map("meter_id") @db.Uuid
  // Rating dimensions that failed to resolve.
  model       String?
  tokenType   String?   @map("token_type")
  periodStart DateTime  @map("period_start") @db.Timestamptz(6)
  periodEnd   DateTime  @map("period_end") @db.Timestamptz(6)
  quantity    Decimal   @default(0) @db.Decimal(38, 9)
  reason      String?
  // open|resolved|written_off — operational, kept as text.
  status      String    @default("open")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt  DateTime? @map("resolved_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  meter        Meter?       @relation(fields: [meterId], references: [id])

  @@index([orgId])
  @@index([customerId])
  @@index([meterId])
  @@map("rating_exceptions")
  @@schema("billing")
}

// CR-9 (new): pricing simulation / backtesting — replay a draft rate card or
// plan against historical usage; reuses the §3.4 pure invoice function.
model SimulationRun {
  id                  String    @id @default(uuid()) @db.Uuid
  orgId               String    @map("org_id") @db.Uuid
  name                String
  // org|segment|all_customers cohort selector.
  scope               String
  // Candidate inputs (logical refs to catalog entities under test).
  candidateRateCardId String?   @map("candidate_rate_card_id") @db.Uuid
  candidatePlanId     String?   @map("candidate_plan_id") @db.Uuid
  periodStart         DateTime  @map("period_start") @db.Timestamptz(6)
  periodEnd           DateTime  @map("period_end") @db.Timestamptz(6)
  // pending|running|completed|failed — operational, kept as text.
  status              String    @default("pending")
  revenueDelta        Decimal?  @map("revenue_delta") @db.Decimal(38, 9)
  // Per-customer revenue delta report.
  resultSummary       Json?     @map("result_summary")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt         DateTime? @map("completed_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@map("simulation_runs")
  @@schema("billing")
}

// =============================================================================
// §5 DEVELOPER & SECURITY — API keys, BYOK, rate limits, webhooks
// =============================================================================

// Conflict C-3: canonical schema is developer; backend api_keys DDL merged in
// (key_hash, source_mode, budget/rate columns). ADR-001 §2.1 rename:
// tenant_id → customer_id, user_id → end_user_id.
model ApiKey {
  id             String       @id @default(uuid()) @db.Uuid
  orgId          String       @map("org_id") @db.Uuid
  // NULLABLE: org-scoped/direct-ingest keys carry no customer (story_11 +
  // OpenAPI ApiKeyCreateRequest require only org_id + name).
  customerId     String?      @map("customer_id") @db.Uuid
  endUserId      String?      @map("end_user_id") @db.Uuid
  name           String
  // SHA-256; = LiteLLM VerificationToken.token (logical link, separate DB).
  keyHash        String       @map("key_hash")
  // sk-live-xxx (11 chars).
  keyPrefix      String       @map("key_prefix")
  sourceMode     SourceMode   @map("source_mode")
  budgetLimitUsd Decimal?     @map("budget_limit_usd") @db.Decimal(38, 9)
  rateLimitRpm   Int?         @map("rate_limit_rpm")
  rateLimitTpm   Int?         @map("rate_limit_tpm")
  allowedModels  Json?        @map("allowed_models")
  status         ApiKeyStatus @default(active)
  lastUsedAt     DateTime?    @map("last_used_at") @db.Timestamptz(6)
  expiresAt      DateTime?    @map("expires_at") @db.Timestamptz(6)
  revokedAt      DateTime?    @map("revoked_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])
  customer     Customer?    @relation(fields: [customerId], references: [id])
  endUser      EndUser?     @relation(fields: [endUserId], references: [id])

  virtualKeyMappings VirtualKeyMapping[]
  rateLimitUsages    RateLimitUsage[]
  securityAuditLogs  SecurityAuditLog[]

  @@index([orgId])
  @@index([customerId])
  @@index([endUserId])
  @@map("api_keys")
  @@schema("developer")
}

model VirtualKeyMapping {
  id            String        @id @default(uuid()) @db.Uuid
  // aka api_key_id in prose.
  virtualKeyId  String        @map("virtual_key_id") @db.Uuid
  providerKeyId String?       @map("provider_key_id")
  orgId         String        @map("org_id") @db.Uuid
  provider      LlmProvider
  keyAlias      String?       @map("key_alias")
  status        MappingStatus @default(active)
  version       Int           @default(1)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?     @map("deleted_at") @db.Timestamptz(6)

  virtualKey   ApiKey           @relation(fields: [virtualKeyId], references: [id])
  providerKey  ByokProviderKey? @relation(fields: [providerKeyId], references: [id])
  organization Organization     @relation(fields: [orgId], references: [id])

  @@index([virtualKeyId])
  @@index([providerKeyId])
  @@index([orgId])
  @@map("virtual_key_mappings")
  @@schema("developer")
}

// story_13:34 — explicit DDL: id is varchar, not uuid.
model ByokProviderKey {
  id           String      @id
  orgId        String      @map("org_id") @db.Uuid
  provider     LlmProvider
  // AES-256-GCM; KMS envelope per ADR-001 §7.
  encryptedKey Bytes       @map("encrypted_key")
  // 12-byte random, never reused.
  keyIv        Bytes       @map("key_iv")
  keyAlias     String?     @map("key_alias")
  keyHash      String?     @map("key_hash")
  keyReference String?     @map("key_reference")
  // No closed value set given in the ERD — kept as text.
  status       String?
  version      Int         @default(1)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?   @map("deleted_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])

  virtualKeyMappings VirtualKeyMapping[]

  @@unique([orgId, provider])
  @@index([orgId])
  @@map("byok_provider_keys")
  @@schema("security")
}

model RateLimitPolicy {
  id        String                @id @default(uuid()) @db.Uuid
  productId String                @map("product_id") @db.Uuid
  name      String                @db.VarChar(255)
  status    RateLimitPolicyStatus @default(DRAFT)

  product Product @relation(fields: [productId], references: [id])

  rules RateLimitRule[]

  @@index([productId])
  @@map("rate_limit_policies")
  @@schema("developer")
}

model RateLimitRule {
  id            String     @id @default(uuid()) @db.Uuid
  policyId      String     @map("policy_id") @db.Uuid
  endpoint      String     @db.VarChar(255)
  requestsLimit Int        @map("requests_limit")
  timeWindow    TimeWindow @map("time_window")
  burstLimit    Int?       @map("burst_limit")

  policy RateLimitPolicy @relation(fields: [policyId], references: [id])

  @@index([policyId])
  @@map("rate_limit_rules")
  @@schema("developer")
}

model RateLimitUsage {
  id           String   @id @default(uuid()) @db.Uuid
  apiKeyId     String   @map("api_key_id") @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  currentUsage Int      @default(0) @map("current_usage")
  windowStart  DateTime @map("window_start") @db.Timestamptz(6)
  windowEnd    DateTime @map("window_end") @db.Timestamptz(6)

  apiKey       ApiKey       @relation(fields: [apiKeyId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])

  @@index([apiKeyId])
  @@index([orgId])
  @@map("rate_limit_usage")
  @@schema("developer")
}

model Webhook {
  id         String        @id @default(uuid()) @db.Uuid
  orgId      String        @map("org_id") @db.Uuid
  name       String
  url        String
  secretHash String        @map("secret_hash")
  events     Json?
  status     WebhookStatus @default(ACTIVE)
  metadata   Json?
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])

  deliveries     WebhookDelivery[]
  retrySchedules WebhookRetrySchedule[]

  @@index([orgId])
  @@map("webhooks")
  @@schema("developer")
}

model WebhookDelivery {
  id             String                @id @default(uuid()) @db.Uuid
  webhookId      String                @map("webhook_id") @db.Uuid
  eventId        String                @map("event_id")
  eventType      String                @map("event_type")
  payload        Json
  requestHeaders Json?                 @map("request_headers")
  responseStatus Int?                  @map("response_status")
  attemptNumber  Int                   @default(1) @map("attempt_number")
  status         WebhookDeliveryStatus @default(PENDING)
  errorMessage   String?               @map("error_message")
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  deliveredAt    DateTime?             @map("delivered_at") @db.Timestamptz(6)
  nextRetryAt    DateTime?             @map("next_retry_at") @db.Timestamptz(6)

  webhook Webhook @relation(fields: [webhookId], references: [id])

  @@index([webhookId])
  @@map("webhook_deliveries")
  @@schema("developer")
}

model WebhookRetrySchedule {
  id            String   @id @default(uuid()) @db.Uuid
  webhookId     String   @map("webhook_id") @db.Uuid
  eventId       String   @map("event_id")
  attemptNumber Int      @map("attempt_number")
  scheduledAt   DateTime @map("scheduled_at") @db.Timestamptz(6)
  // No closed value set given in the ERD — kept as text.
  status        String?

  webhook Webhook @relation(fields: [webhookId], references: [id])

  @@index([webhookId])
  @@map("webhook_retry_schedules")
  @@schema("developer")
}

// =============================================================================
// §6 PLATFORM OPS — audit, compliance, alerts, reports, workflow, AI analytics
// =============================================================================

// Conflict C-7: CANONICAL actor-action audit — absorbs bare audit_logs,
// shared.audit_logs, customer.audit_logs.
model AuditLog {
  id           String      @id @default(uuid()) @db.Uuid
  orgId        String      @map("org_id") @db.Uuid
  userId       String?     @map("user_id") @db.Uuid
  action       String
  resourceType String      @map("resource_type")
  resourceId   String?     @map("resource_id")
  oldValue     Json?       @map("old_value")
  newValue     Json?       @map("new_value")
  ipAddress    String?     @map("ip_address") @db.Inet
  userAgent    String?     @map("user_agent")
  status       AuditStatus @default(SUCCESS)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [orgId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([orgId])
  @@index([userId])
  @@map("audit_logs")
  @@schema("platform")
}

// Conflict C-7: security violations only (actor actions → platform.audit_logs).
// Hosted in the `audit` schema per the ERD/story canon.
// org_id is NULLABLE: invalid-key attempts often have no resolvable org — such
// rows carry org_id = NULL with key_prefix + reason in `details` (never a
// literal "unknown"; the column is a UUID FK).
model SecurityAuditLog {
  id            String        @id @default(uuid()) @db.Uuid
  orgId         String?       @map("org_id") @db.Uuid
  apiKeyId      String?       @map("api_key_id") @db.Uuid
  customerId    String?       @map("customer_id") @db.Uuid
  violationType ViolationType @map("violation_type")
  ipAddress     String?       @map("ip_address") @db.Inet
  // Max 1000 chars.
  details       String?       @db.VarChar(1000)
  triggeredBy   String?       @map("triggered_by")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization? @relation(fields: [orgId], references: [id])
  apiKey       ApiKey?       @relation(fields: [apiKeyId], references: [id])
  customer     Customer?     @relation(fields: [customerId], references: [id])

  @@index([orgId])
  @@index([apiKeyId])
  @@index([customerId])
  @@map("security_audit_logs")
  @@schema("audit")
}

// CR-12 (new): billing-sandbox time control — time is an input, never sampled
// (ADR-001 §3.4 purity invariant).
model TestClock {
  id       String   @id @default(uuid()) @db.Uuid
  orgId    String   @map("org_id") @db.Uuid
  frozenAt DateTime @map("frozen_at") @db.Timestamptz(6)
  // active|advancing|released — operational, kept as text.
  status   String?

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@map("test_clocks")
