{
  "realm": "quantumbilling",
  "enabled": true,
  "displayName": "QuantumBilling",
  "roles": {
    "realm": [
      { "name": "SUPER_ADMIN", "description": "Platform administrator" },
      { "name": "ORG_ADMIN", "description": "Organization administrator" },
      { "name": "CUSTOMER", "description": "Customer user" },
      { "name": "END_USER", "description": "End user" },
      { "name": "DEVELOPER", "description": "Developer/API key manager" }
    ]
  },
  "clients": [
    {
      "clientId": "quantumbilling-bff",
      "name": "QuantumBilling BFF",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "dev-bff-client-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "redirectUris": ["http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3000"]
    }
  ]
}
